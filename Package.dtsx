          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{D89E474D-2260-4D85-93E3-169A2CA7F047}"
              SQLTask:SqlStatementSource="&#xA;DELETE FROM [Clean].[Fact_Franchise];&#xA;DELETE FROM [Clean].[Dim_Studio];&#xA;DELETE FROM [Clean].[Dim_Genre];&#xA;DELETE FROM [Clean].[Dim_Classification];&#xA;DELETE FROM [Clean].[Dim_Source];&#xA;DELETE FROM [Clean].[Dim_Date];&#xA;&#xA;&#xA;INSERT INTO [Clean].[Dim_Studio] (Studio_id, Studio_Nom)&#xA;SELECT Studio_id, Studio_Nom FROM [Staging].[Dim_Studio];&#xA;&#xA;INSERT INTO [Clean].[Dim_Genre] (Genre_id, Genre_Nom)&#xA;SELECT Genre_id, Genre_Nom FROM [Staging].[Dim_Genre];&#xA;&#xA;INSERT INTO [Clean].[Dim_Classification] (Classification_id, Rating_Code, Status_Nom)&#xA;SELECT Classification_id, Rating_Code, Status_Nom FROM [Staging].[Dim_Classification];&#xA;&#xA;INSERT INTO [Clean].[Dim_Source] (Source_id, Source_Nom)&#xA;SELECT Source_id, Source_Nom FROM [Staging].[Dim_Source];&#xA;&#xA;INSERT INTO [Clean].[Dim_Date] (Date_id, Sortie_Date, Annee, Mois, Saison_Nom)&#xA;SELECT Date_id, Sortie_Date, Annee, Mois, Saison_Nom FROM [Staging].[Dim_Date];&#xA;&#xA;&#xA;INSERT INTO [Clean].[Fact_Franchise]&#xA;SELECT * FROM [Staging].[Fact_Franchise];" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\TRANSFORM"
      DTS:CreationName="STOCK:SEQUENCE"
      DTS:Description="Conteneur de séquences"
      DTS:DTSID="{B31E85B9-E396-4077-BE81-F8BBB72C903D}"
      DTS:ExecutableType="STOCK:SEQUENCE"
      DTS:LocaleID="-1"
      DTS:ObjectName="TRANSFORM">
      <DTS:Variables />
      <DTS:Executables>
        <DTS:Executable
          DTS:refId="Package\TRANSFORM\Dim Filter"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Tâche d'exécution de requêtes SQL"
          DTS:DTSID="{C8AC3791-482E-4585-ACB5-2D2419EC363B}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Dim Filter"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{D89E474D-2260-4D85-93E3-169A2CA7F047}"
              SQLTask:SqlStatementSource="TRUNCATE TABLE [Staging].[Dim_Source];&#xA;INSERT INTO [Staging].[Dim_Source] (Source_Nom)&#xA;SELECT DISTINCT [Source] FROM [Staging].[JIKAN] WHERE [Source] IS NOT NULL;&#xA;&#xA;TRUNCATE TABLE [Staging].[Dim_Studio];&#xA;INSERT INTO [Staging].[Dim_Studio] (Studio_Nom)&#xA;SELECT DISTINCT [Studio_Principal] FROM [Staging].[JIKAN] WHERE [Studio_Principal] IS NOT NULL;&#xA;&#xA;TRUNCATE TABLE [Staging].[Dim_Genre];&#xA;INSERT INTO [Staging].[Dim_Genre] (Genre_Nom)&#xA;SELECT DISTINCT [Genre_Principal] FROM [Staging].[JIKAN] WHERE [Genre_Principal] IS NOT NULL;&#xA;&#xA;TRUNCATE TABLE [Staging].[Dim_Classification];&#xA;INSERT INTO [Staging].[Dim_Classification] (Rating_Code, Status_Nom)&#xA;SELECT DISTINCT [Rating], [Status] FROM [Staging].[JIKAN] WHERE [Rating] IS NOT NULL OR [Status] IS NOT NULL;&#xA;&#xA;TRUNCATE TABLE [Staging].[Dim_Date];&#xA;INSERT INTO [Staging].[Dim_Date] (Sortie_Date, Annee, Mois, Saison_Nom)&#xA;SELECT DISTINCT &#xA;    TRY_CAST(LEFT([Date_Sortie], 10) AS DATE),&#xA;    YEAR(TRY_CAST(LEFT([Date_Sortie], 10) AS DATE)),&#xA;    MONTH(TRY_CAST(LEFT([Date_Sortie], 10) AS DATE)),&#xA;    [Saison]&#xA;FROM [Staging].[JIKAN]&#xA;WHERE [Date_Sortie] IS NOT NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\TRANSFORM\Fact Filter"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Tâche d'exécution de requêtes SQL"
          DTS:DTSID="{7D021CE9-3A38-43A5-B796-B0DCD30A467A}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Fact Filter"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{D89E474D-2260-4D85-93E3-169A2CA7F047}"
              SQLTask:SqlStatementSource="TRUNCATE TABLE [Staging].[Fact_Franchise];&#xA;&#xA;WITH CTE_Animes_Uniques AS (&#xA;    SELECT &#xA;        *,&#xA;        ROW_NUMBER() OVER(PARTITION BY [Anime_ID] ORDER BY [Anime_ID]) as rn&#xA;    FROM [Staging].[JIKAN]&#xA;)&#xA;INSERT INTO [Staging].[Fact_Franchise] (&#xA;    [anime_id],&#xA;    [date_id],&#xA;    [studio_id],&#xA;    [genre_id],&#xA;    [classification_id],&#xA;    [source_id],&#xA;    [titre],&#xA;    [score],&#xA;    [votants_nombre],&#xA;    [membres_nombre],&#xA;    [favoris],&#xA;    [episodes_nombre],&#xA;    [episodes_minute_duree],&#xA;    [predit_score]&#xA;)&#xA;SELECT &#xA;    j.[Anime_ID],&#xA;    &#xA;    dd.[Date_id],&#xA;    ds.[Studio_id],&#xA;    dg.[Genre_id],&#xA;    dc.[Classification_id],&#xA;    dso.[Source_id],&#xA;    &#xA;    j.[Titre],&#xA;    &#xA;    TRY_CAST(j.[Score] AS DECIMAL(4,2)) AS score,&#xA;    &#xA;    TRY_CAST(TRY_CAST(j.[Nombre_Votants] AS FLOAT) AS INT) AS votants_nombre,&#xA;    TRY_CAST(TRY_CAST(j.[Nombre_Membres] AS FLOAT) AS INT) AS membres_nombre,&#xA;    TRY_CAST(TRY_CAST(j.[Favoris] AS FLOAT) AS INT) AS favoris,&#xA;    &#xA;    (TRY_CAST(TRY_CAST(j.[Nombre_Episodes] AS FLOAT) AS INT) / 10) AS episodes_nombre,&#xA;    &#xA;    TRY_CAST(SUBSTRING(j.[Duree_Brute], 1, CHARINDEX(' ', j.[Duree_Brute] + ' ') - 1) AS INT) AS episodes_minute_duree,&#xA;    &#xA;    NULL AS predit_score&#xA;&#xA;FROM CTE_Animes_Uniques j&#xA;&#xA;LEFT JOIN [Staging].[Dim_Date] dd &#xA;    ON TRY_CAST(LEFT(j.[Date_Sortie], 10) AS DATE) = dd.[Sortie_Date]&#xA;   AND ISNULL(j.[Saison], 'N/A') = ISNULL(dd.[Saison_Nom], 'N/A')&#xA;   &#xA;LEFT JOIN [Staging].[Dim_Studio] ds &#xA;    ON j.[Studio_Principal] = ds.[Studio_Nom]&#xA;LEFT JOIN [Staging].[Dim_Genre] dg &#xA;    ON j.[Genre_Principal] = dg.[Genre_Nom]&#xA;LEFT JOIN [Staging].[Dim_Classification] dc &#xA;    ON ISNULL(j.[Rating], 'N/A') = ISNULL(dc.[Rating_Code], 'N/A') &#xA;   AND ISNULL(j.[Status], 'N/A') = ISNULL(dc.[Status_Nom], 'N/A')&#xA;LEFT JOIN [Staging].[Dim_Source] dso &#xA;    ON j.[Source] = dso.[Source_Nom]&#xA;&#xA;WHERE j.rn = 1;&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
      <DTS:PrecedenceConstraints>
        <DTS:PrecedenceConstraint
          DTS:refId="Package\TRANSFORM.PrecedenceConstraints[Contrainte]"
          DTS:CreationName=""
          DTS:DTSID="{CF1B08EB-454F-4BE0-9FA8-5F387A4C4848}"
          DTS:From="Package\TRANSFORM\Dim Filter"
          DTS:LogicalAnd="True"
          DTS:ObjectName="Contrainte"
          DTS:To="Package\TRANSFORM\Fact Filter" />
      </DTS:PrecedenceConstraints>
    </DTS:Executable>
  </DTS:Executables>
